page {
  background: #f6f7f9;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

.page {
  padding: 24rpx;
}

.section {
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 16rpx;
}

.muted {
  color: #6b7280;
  font-size: 24rpx;
}

.row {
  align-items: center;
  display: flex;
  gap: 16rpx;
}

.between {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.field {
  margin-bottom: 18rpx;
}

.label {
  color: #374151;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

input,
textarea {
  background: #f9fafb;
  border: 1rpx solid #d1d5db;
  border-radius: 8rpx;
  box-sizing: border-box;
  min-height: 76rpx;
  padding: 16rpx;
  width: 100%;
}

textarea {
  min-height: 144rpx;
}

button {
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 2.4;
  margin: 0;
}

.primary {
  background: #2563eb;
  color: #ffffff;
}

.secondary {
  background: #eef2ff;
  color: #1d4ed8;
}

.danger {
  background: #fee2e2;
  color: #b91c1c;
}

.ghost {
  background: #f3f4f6;
  color: #374151;
}

.list-item {
  border-bottom: 1rpx solid #e5e7eb;
  padding: 20rpx 0;
}

.list-item:last-child {
  border-bottom: 0;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
}

.item-meta {
  color: #6b7280;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.empty {
  color: #9ca3af;
  padding: 48rpx 0;
  text-align: center;
}
