<view class="page">
  <view class="section">
    <view class="title">{{customer.customerName || '客户详情'}}</view>
    <view class="field">
      <view class="label">联系电话</view>
      <view>{{customer.phone || '-'}}</view>
    </view>
    <view class="field">
      <view class="label">地址</view>
      <view>{{customer.address || '-'}}</view>
    </view>
    <view class="field">
      <view class="label">备注</view>
      <view>{{customer.remark || '-'}}</view>
    </view>
    <button class="primary" bindtap="goEdit">编辑</button>
  </view>
</view>
