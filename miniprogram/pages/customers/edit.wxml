<view class="page">
  <view class="section">
    <view class="title">{{id ? '编辑客户' : '新增客户'}}</view>
    <view class="field">
      <view class="label">客户名称</view>
      <input value="{{form.customerName}}" data-field="customerName" bindinput="onInput" placeholder="请输入客户名称" />
    </view>
    <view class="field">
      <view class="label">联系电话</view>
      <input value="{{form.phone}}" data-field="phone" bindinput="onInput" placeholder="请输入联系电话" />
    </view>
    <view class="field">
      <view class="label">地址</view>
      <input value="{{form.address}}" data-field="address" bindinput="onInput" placeholder="请输入地址" />
    </view>
    <view class="field">
      <view class="label">备注</view>
      <textarea value="{{form.remark}}" data-field="remark" bindinput="onInput" placeholder="请输入备注" />
    </view>
    <button class="primary" loading="{{saving}}" bindtap="onSubmit">保存</button>
  </view>
</view>
