<view class="page">
  <view class="between section">
    <view>
      <view class="title">客户列表</view>
      <view class="muted">共 {{total}} 条</view>
    </view>
    <button class="primary" size="mini" bindtap="goCreate">新增</button>
  </view>

  <view class="section">
    <block wx:if="{{customers.length}}">
      <view class="list-item" wx:for="{{customers}}" wx:key="customerId">
        <view class="between">
          <view bindtap="goDetail" data-id="{{item.customerId}}">
            <view class="item-title">{{item.customerName}}</view>
            <view class="item-meta">{{item.phone || '无电话'}} · {{item.address || '无地址'}}</view>
          </view>
          <view class="row">
            <button class="secondary" size="mini" data-id="{{item.customerId}}" bindtap="goEdit">编辑</button>
            <button class="danger" size="mini" data-id="{{item.customerId}}" bindtap="onDelete">删除</button>
          </view>
        </view>
      </view>
    </block>
    <view wx:else class="empty">暂无客户</view>
  </view>
</view>
